# Environment variables for the news scraper application
# Copy this file to .env and fill in your actual values

# =============================================================================
# AZURE OPENAI CONFIGURATION (REQUIRED)
# =============================================================================
# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Your Azure OpenAI endpoint URL
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Azure OpenAI API version (usually 2024-02-01)
AZURE_OPENAI_API_VERSION=2024-02-01

# =============================================================================
# SEARCH API CONFIGURATION (OPTIONAL)
# =============================================================================
# Bing Search API key (for web search functionality)
BING_SUBSCRIPTION_KEY=your_bing_api_key_here

# Bing Search URL (default is fine for most cases)
BING_SEARCH_URL=https://api.bing.microsoft.com/v7.0/search

# Serper API key (alternative search provider)
SERPER_API_KEY=your_serper_api_key_here

# =============================================================================
# APIFY CONFIGURATION (OPTIONAL)
# =============================================================================
# Apify API token (for web crawling functionality)
APIFY_API_TOKEN=your_apify_api_token_here

# =============================================================================
# SSL CONFIGURATION (OPTIONAL)
# =============================================================================
# SSL certificate file path (if using HTTPS)
SSL_CERTFILE=cert.pem

# SSL private key file path (if using HTTPS)
SSL_KEYFILE=key.pem

# =============================================================================
# SERVER CONFIGURATION (OPTIONAL)
# =============================================================================
# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8280)
PORT=8280

# Enable reload for development (default: false for production)
RELOAD=false
