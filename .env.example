# Environment variables for the adverse news screening application
# Copy this file to .env and fill in your actual values

# =============================================================================
# AZURE OPENAI CONFIGURATION (REQUIRED)
# =============================================================================
# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Your Azure OpenAI endpoint URL
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# OpenAI API version (usually 2025-03-01-preview)
OPENAI_API_VERSION=2025-03-01-preview

# =============================================================================
# DEEPSEEK CONFIGURATION (REQUIRED)
# =============================================================================
# DeepSeek API key for DeepSeek LLM models
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# TONGYI QWEN CONFIGURATION (REQUIRED)
# =============================================================================
# DashScope API key for Tongyi Qwen models (Alibaba Cloud)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# =============================================================================
# SEARCH API CONFIGURATION (OPTIONAL)
# =============================================================================
# Bing Search API key (for web search functionality)
BING_SUBSCRIPTION_KEY=your_bing_api_key_here

# Bing Search URL (default is fine for most cases)
BING_SEARCH_URL=https://api.bing.microsoft.com/v7.0/search

# Serper API key (alternative search provider)
SERPER_API_KEY=your_serper_api_key_here

# Brave Search API key (privacy-focused search engine)
BRAVE_API_KEY=your_brave_api_key_here

# Tavily API key (AI-optimized search engine)
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# APIFY CONFIGURATION (OPTIONAL)
# =============================================================================
# Apify API token (for web crawling functionality)
APIFY_API_TOKEN=your_apify_api_token_here

# =============================================================================
# MONGODB CONFIGURATION (OPTIONAL)
# =============================================================================
# MongoDB connection URI (default: mongodb://localhost:27017)
MONGO_URI=mongodb://localhost:27017

# MongoDB database name (default: adverse_news_screening)
MONGO_DB=adverse_news_screening

# MongoDB collection name for web contents (default: web_contents)
MONGO_CONTENTS_COLLECTION=web_contents

# MongoDB collection name for tags (default: fc_tags)
MONGO_TAGS_COLLECTION=fc_tags

# =============================================================================
# REDIS CONFIGURATION (OPTIONAL)
# =============================================================================
# Redis connection URL (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# =============================================================================
# SSL CONFIGURATION (OPTIONAL)
# =============================================================================
# SSL certificate file path (if using HTTPS)
SSL_CERTFILE=cert.pem

# SSL private key file path (if using HTTPS)
SSL_KEYFILE=key.pem

# =============================================================================
# SERVER CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable reload for development (default: false for production)
RELOAD=false

# VI deployment mode (default: false)
VI_DEPLOY=false

# =============================================================================
# IFRAME EMBEDDING CONFIGURATION (OPTIONAL)
# =============================================================================
# Allow IFRAME embedding (default: false for security)
ALLOW_IFRAME_EMBEDDING=true

# Allowed parent domains for IFRAME embedding (comma-separated)
# Use "*" for all domains (not recommended for production)
IFRAME_ALLOWED_ORIGINS=*

# =============================================================================
# COOKIE AND SECURITY CONFIGURATION (OPTIONAL)
# =============================================================================
# SameSite policy for cookies (None, Lax, Strict)
# None: Allows cross-site requests (required for IFRAME embedding with cross-origin)
# Lax: Allows some cross-site requests (default, good for most cases)  
# Strict: No cross-site requests allowed (most secure, may break IFRAME functionality)
COOKIE_SAMESITE=None

# Secure cookies (true for HTTPS, false for HTTP)
# Note: SameSite=None requires Secure=true (HTTPS)
COOKIE_SECURE=true

# Cookie domain (leave empty for default)
COOKIE_DOMAIN=

# Session cookie max age in seconds (default: 86400 = 24 hours)
SESSION_MAX_AGE=86400

# Session secret key (generate a secure random key for production)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your_secure_session_secret_key_here
