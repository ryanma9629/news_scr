# Environment variables for the adverse news screening application
# Copy this file to .env and fill in your actual values

# =============================================================================
# AZURE OPENAI CONFIGURATION (REQUIRED)
# =============================================================================
# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Your Azure OpenAI endpoint URL
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# OpenAI API version (usually 2025-03-01-preview)
OPENAI_API_VERSION=2025-03-01-preview

# =============================================================================
# DEEPSEEK CONFIGURATION (REQUIRED)
# =============================================================================
# DeepSeek API key for DeepSeek LLM models
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =============================================================================
# TONGYI QWEN CONFIGURATION (REQUIRED)
# =============================================================================
# DashScope API key for Tongyi Qwen models (Alibaba Cloud)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# =============================================================================
# SEARCH API CONFIGURATION (OPTIONAL)
# =============================================================================
# Bing Search API key (for web search functionality)
BING_SUBSCRIPTION_KEY=your_bing_api_key_here

# Bing Search URL (default is fine for most cases)
BING_SEARCH_URL=https://api.bing.microsoft.com/v7.0/search

# Serper API key (alternative search provider)
SERPER_API_KEY=your_serper_api_key_here

# =============================================================================
# APIFY CONFIGURATION (OPTIONAL)
# =============================================================================
# Apify API token (for web crawling functionality)
APIFY_API_TOKEN=your_apify_api_token_here

# =============================================================================
# MONGODB CONFIGURATION (OPTIONAL)
# =============================================================================
# MongoDB connection URI (default: mongodb://localhost:27017)
MONGO_URI=mongodb://localhost:27017

# MongoDB database name (default: adverse_news_screening)
MONGO_DB=adverse_news_screening

# MongoDB collection name for web contents (default: web_contents)
MONGO_CONTENTS_COLLECTION=web_contents

# MongoDB collection name for tags (default: fc_tags)
MONGO_TAGS_COLLECTION=fc_tags

# =============================================================================
# POSTGRESQL CONFIGURATION (REQUIRED WHEN USING DOCKER)
# =============================================================================
# PostgreSQL connection parameters
POSTGRES_HOST=localhost
POSTGRES_PORT=8432
POSTGRES_DB=adverse_news_screening
POSTGRES_USER=postgres
# REQUIRED: Set a secure password for PostgreSQL
POSTGRES_PASSWORD=your_secure_postgres_password_here

# PostgreSQL table name for tags (default: fc_tags)
POSTGRES_TAGS_TABLE=fc_tags

# =============================================================================
# SSL CONFIGURATION (OPTIONAL)
# =============================================================================
# SSL certificate file path (if using HTTPS)
SSL_CERTFILE=cert.pem

# SSL private key file path (if using HTTPS)
SSL_KEYFILE=key.pem

# =============================================================================
# SERVER CONFIGURATION (OPTIONAL)
# =============================================================================
# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Server port (default: 8280)
PORT=8280

# Enable reload for development (default: false for production)
RELOAD=false

# VI deployment mode (default: false)
VI_DEPLOY=false
