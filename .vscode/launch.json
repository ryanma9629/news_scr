{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "FastAPI App",
            "type": "debugpy",
            "request": "launch",
            "module": "app.main",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": []
        },
        {
            "name": "FastAPI App (with reload)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "RELOAD": "true"
            },
            "console": "integratedTerminal",
            "justMyCode": false,
            "args": [
                "app.main:app",
                "--host", "0.0.0.0",
                "--port", "8280",
                "--reload"
            ]
        },
        {
            "name": "Python Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false
        }
    ]
}
